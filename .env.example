NEXT_PUBLIC_WHATSAPP_NUMBER=+529980000000
NEXT_PUBLIC_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/REPLACE_ME

# ─────────────────────────────────────────────────────────────
# Sanity (CMS)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
SANITY_API_TOKEN=

# ─────────────────────────────────────────────────────────────
# Stripe (apartado $50K MXN)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ─────────────────────────────────────────────────────────────
# Asesores (login interno para Drives de Ventas)
# ─────────────────────────────────────────────────────────────
# Correo fijo del único asesor (default hello@tresor.mx si se omite)
ASESOR_EMAIL=hello@tresor.mx
# Contraseña del asesor
ASESOR_PASSWORD=
# Secreto para firmar la cookie de sesión (HMAC). OBLIGATORIO en producción:
# sin un valor propio, la cookie httpOnly sería falsificable. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ASESOR_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────
# Brokers (registro externo — cuentas reales por persona en Sanity)
# ─────────────────────────────────────────────────────────────
# Secreto para firmar la cookie de sesión de cada broker (HMAC). OBLIGATORIO
# en producción, distinto de ASESOR_SESSION_SECRET. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BROKER_SESSION_SECRET=

# ─────────────────────────────────────────────────────────────
# Anthropic (chatbot)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Resend (emails internos)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=ventas@quattroplaza.mx
LEADS_EMAIL_TO=david.baena@gmail.com

# ─────────────────────────────────────────────────────────────
# Go High Level (CRM + calendario)
# ─────────────────────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
# Calendario Round Robin de /agenda — reparte citas entre sus team members
GHL_CALENDAR_ID=
